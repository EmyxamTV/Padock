PADOCK_JWT_SECRET=replace-with-a-long-random-secret
PADOCK_NODE_TOKEN=replace-with-a-second-random-secret-of-at-least-32-characters
PADOCK_DATABASE_PASSWORD=replace-with-a-strong-database-password

# Domaine HTTPS ajouté dans Dokploy sur le service padock, port 3000.
PADOCK_PUBLIC_URL=https://panel.example.com

# Domaine de base des serveurs. Créez *.mc.example.com vers l'IP du serveur Dokploy.
PADOCK_GATEWAY_DOMAIN=mc.example.com
PADOCK_GATEWAY_DNS_TARGET=203.0.113.10

PADOCK_SERVERS_DIR=/var/lib/padock/servers
PADOCK_BACKUPS_DIR=/var/lib/padock/backups
PADOCK_SFTP_PUBLIC_HOST=sftp.example.com
PADOCK_SFTP_PUBLIC_PORT=2022
PADOCK_MINECRAFT_IMAGE=itzg/minecraft-server:java25
DOCKER_GID=999

# Les apostrophes protègent les caractères spéciaux $, #, ! et &.
CURSEFORGE_API_KEY=''
