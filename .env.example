PADOCK_PORT=3000
PADOCK_HOST=0.0.0.0
PADOCK_PANEL_DATA_DIR=/var/lib/padock/panel
PADOCK_SERVERS_DIR=/var/lib/padock/servers
PADOCK_BACKUPS_DIR=/var/lib/padock/backups
PADOCK_JWT_SECRET=change-this-with-a-long-random-secret
PADOCK_NODE_TOKEN=change-this-with-a-second-random-secret-of-at-least-32-characters
PADOCK_DATABASE_PASSWORD=change-this-database-password
PADOCK_PUBLIC_URL=http://localhost:3000
PADOCK_SFTP_PUBLIC_HOST=localhost
PADOCK_SFTP_PUBLIC_PORT=2022
PADOCK_MINECRAFT_IMAGE=itzg/minecraft-server:java25
# Utilisé par compose.dokploy.yaml. Le wildcard *.mc.example.com doit pointer vers l'IP Dokploy.
PADOCK_GATEWAY_DOMAIN=mc.example.com
PADOCK_GATEWAY_DNS_TARGET=
# Conservez les apostrophes : elles protègent les caractères $, #, ! et &.
CURSEFORGE_API_KEY=''
